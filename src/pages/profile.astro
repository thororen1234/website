---
import Avatar from '@/components/Base/Avatar.astro'
import Head from '@/components/Layout/Head.astro'
---

<!doctype html>
<html lang="en">
    <head>
        <Head
            title="thororen"
            description="I'm a software developer from the United States of America with experience in languages such as TypeScript, JavaScript, Python, and Go."
        />
        <link rel="icon" type="image/png" href="/assets/favicon.png" />
    </head>
    <body class="wrapper">
        <main class="wrapper">
            <section class="card">
                <div class="card-inner">
                    <div class="card-header">
                        <Avatar size={64} />
                        <div class="profile-meta">
                            <div class="title-row">
                                <span class="display-name">thororen</span>
                                <span
                                    id="presence-pill"
                                    class="status-pill offline">offline</span
                                >
                            </div>
                            <div class="subtitle-row">
                                <div class="subtitle-top">
                                    <span>He/Him</span>
                                    <span class="bullet"></span>
                                    <span id="profile-local-time">--:--</span>
                                </div>
                                <div
                                    id="profile-custom-status"
                                    class="embed-field hidden"
                                >
                                    <span
                                        id="profile-custom-status-text"
                                        class="embed-value"></span>
                                </div>
                                <div
                                    id="profile-activity-row"
                                    class="embed-field hidden"
                                >
                                    <span
                                        id="profile-activity-text"
                                        class="embed-value"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </body>
</html>

<style>
    :root {
        color-scheme: dark;
    }

    html {
        max-width: 100%;
    }

    body {
        min-height: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: Inter, system-ui, sans-serif;
        color: #e5e7eb;
    }

    img {
        max-width: 100%;
        display: block;
    }

    .wrapper {
        max-width: 100%;
        justify-content: left;
    }

    .card {
        max-width: 100%;
        border-radius: 20px;
        background: rgba(15, 23, 42, 0.96);
        border: 1px solid rgba(148, 163, 184, 0.12);
        box-shadow: 0 24px 72px rgba(0, 0, 0, 0.25);
        overflow: hidden;
    }

    .card-inner {
        padding: 1.2rem;
        display: grid;
        gap: 1rem;
    }

    .card-header {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.85rem;
        align-items: center;
    }

    .profile-meta {
        display: grid;
    }

    .title-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.65rem;
    }

    .display-name {
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1;
    }

    .subtitle-row {
        display: grid;
        gap: 0.4rem;
        color: #94a3b8;
        font-size: 0.85rem;
    }

    .subtitle-top {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
        align-items: center;
    }

    .bullet {
        width: 0.35rem;
        height: 0.35rem;
        border-radius: 9999px;
        background: rgba(148, 163, 184, 0.5);
        display: inline-block;
    }

    .status-pill {
        font-size: 0.82rem;
        line-height: 1;
    }

    .status-pill.online {
        color: #a7f3d0;
    }
    .status-pill.idle {
        background: rgba(240, 178, 50, 0.18);
        color: #fde68a;
    }
    .status-pill.dnd {
        color: #fecaca;
    }
    .status-pill.offline {
        color: #cbd5e1;
    }

    .embed-field {
        display: grid;
        gap: 0.35rem;
    }

    .embed-value {
        color: #e2e8f0;
        font-size: 0.75rem;
        line-height: 1;
    }

    .hidden {
        display: none;
    }

    @media (max-width: 640px) {
        body {
            padding: 1rem;
        }

        .card-header {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    const userId = '848339671629299742'
    async function fetchTimezone() {
        try {
            const res = await fetch(
                `https://timezone.creations.works/get?id=${userId}`,
            )
            if (!res.ok) throw new Error()
            const data = await res.json()
            return data.timezone || 'America/New_York'
        } catch {
            return 'America/New_York'
        }
    }

    function initLocalTime(timezone: string) {
        const el = document.getElementById('profile-local-time')
        if (!el) return

        const fmt = new Intl.DateTimeFormat('en-US', {
            timeZone: timezone,
            hour: '2-digit',
            minute: '2-digit',
            hour12: true,
        })

        const update = () => {
            el.textContent = fmt.format(new Date())
        }
        update()
        setInterval(update, 60_000)
    }

    async function loadProfile() {
        try {
            const res = await fetch(
                `https://lanyard.equicord.org/v1/users/${userId}`,
            )
            if (!res.ok) throw new Error('Lanyard fetch failed')

            const { data } = await res.json()

            const status = data?.discord_status ?? 'offline'
            const pill = document.getElementById('presence-pill')
            if (pill) {
                pill.textContent = status
                pill.className = `status-pill ${status}`
            }

            const custom = data?.activities?.find(
                (a: { type: number }) => a.type === 4,
            )
            if (custom?.state) {
                document.getElementById(
                    'profile-custom-status-text',
                )!.textContent = custom.state
                document
                    .getElementById('profile-custom-status')!
                    .classList.remove('hidden')
            }

            const activity = data?.activities?.find(
                (a: { type: number }) => a.type !== 4,
            )
            if (activity) {
                const isSpotify = activity.name === 'Spotify'
                const text =
                    isSpotify && activity.details && activity.state
                        ? `${activity.details} — ${activity.state}`
                        : `Listening to ${activity.details || activity.name || ''}`

                document.getElementById('profile-activity-text')!.textContent =
                    text
                document
                    .getElementById('profile-activity-row')!
                    .classList.remove('hidden')
            }
        } catch (err) {
            console.error('Failed to load profile preview', err)
        }
    }

    const timezone = await fetchTimezone()
    initLocalTime(timezone)
    await loadProfile()
</script>
